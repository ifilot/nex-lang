#
# String concatenation and string comparisons.
# Shows that strings can participate in both expressions and control flow.
#
str greeting = "Hello";
str subject = "NEX";
str message = greeting + ", " + subject + "!";
print(message);

if ("apple" < "banana") {
    print("ordered");
} else {
    print("unordered");
}

if (message == "Hello, NEX!") {
    print("exact match");
} else {
    print("different");
}

if (message != "Hello, World!") {
    print("custom target");
} else {
    print("default target");
}
