#
# A tour of the three supported `for` loop shapes.
# Shows declaration-based, assignment-based, and manual iteration clauses.
#

# Regular `for` loop with a declaration in the initializer.
int N = 3;
for(int i=0; i<N; i=i++) {
    print(i);
}

# Reuse an existing variable in the initializer.
int i=-10;
for(i=0; i<N; i=i++) {
    print(i);
}

# Omit both the initializer and the iteration clause.
i=0;
for(; i<N;) {
    print(i);
    i=i+1;
}
