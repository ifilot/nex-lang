#
# Classic FizzBuzz.
# Demonstrates modulo arithmetic plus nested `if` / `else` blocks.
#
for(int i=1; i<=15; i=i+1) {
    if (i % 3 == 0) {
        if (i % 5 == 0) {
            print("FizzBuzz");
        } else {
            print("Fizz");
        }
    } else {
        if (i % 5 == 0) {
            print("Buzz");
        } else {
            print(i);
        }
    }
}
