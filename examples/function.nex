#
# Demo with a number of functions, including recursive functions
#

#
# Simple Hello World function
#
fn hello_world() -> void {
    print("Hello World!");
}
hello_world();

#
# Addition function with multiple parameters
#
fn add(int a, int b) -> int {
    return a+b;
}
print(add(1,2));

#
# Factorial function using recursion
#
fn fact(int n) -> int {
    if(n == 1) {
        return 1;
    }

    return n * fact(n - 1);
}

print(fact(6));


